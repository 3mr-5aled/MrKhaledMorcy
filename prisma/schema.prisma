// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// User model for teacher/admin authentication
model User {
  id         String     @id @default(cuid())
  email      String     @unique
  name       String?
  password   String     // bcrypt hashed
  role              Role          @default(ADMIN)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  activities        Activity[]
  uploadedFiles     File[]        @relation("UploadedFiles")
  createdVersions   FileVersion[] @relation("CreatedVersions")

  @@map("users")
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

// Grade model (e.g., "أولى إعدادي", "ثالثة ثانوي")
model Grade {
  id        String   @id @default(cuid())
  name      String   // "أولى إعدادي"
  slug      String   @unique // "prep-1", "sec-3"
  stage     String   // "المرحلة الإعدادية" or "المرحلة الثانوية"
  color     String?  // Hex color for UI
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  units     Unit[]
  answers   Answer[]
  quizzes   Quiz[]
  students  Student[]
  liveSessions LiveSession[]
  sessionCodes SessionCode[]

  @@map("grades")
}

// Unit model (e.g., "Unit 1", "Unit 2")
model Unit {
  id        String   @id @default(cuid())
  name      String   // "Unit 1"
  slug      String   // "unit-1", "unit-2"
  gradeId   String
  grade     Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  lessons   Lesson[]
  answers   Answer[]
  quizzes   Quiz[]

  @@unique([gradeId, slug])
  @@map("units")
}

// Lesson model (e.g., "Lesson 1", "Lesson 2")
model Lesson {
  id        String   @id @default(cuid())
  name      String   // "Lesson 1"
  unitId    String
  unit      Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  answers   Answer[]
  quizzes   Quiz[]

  @@map("lessons")
}

// Answer model for storing lesson answers, unit exercises, exams, etc.
model Answer {
  id           String        @id @default(cuid())
  title        String        // "إجابات الدرس الأول" or "تمارين على الوحدة 1 و 2"
  description  String?       @db.Text
  type         AnswerType    // PDF, IMAGE, YOUTUBE
  url          String        // File path or YouTube URL (single file for PDF/YouTube)
  images       String[]      // Array of image paths (for IMAGE type only)
  thumbnails   String[]      @default([]) // Array of thumbnail paths (for IMAGE type only)
  externalUrl  String?       // External URL for any external link
  lessonId     String?
  lesson       Lesson?       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  unitId       String?       // Direct unit reference for unit-level answers
  unit         Unit?         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  gradeId      String?       // Direct grade reference for grade-level answers
  grade        Grade?        @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  categoryType CategoryType  // LESSON, UNIT_EXERCISE, EXAM, OTHER
  customTitle  String?       // For OTHER category type
  order        Int           @default(0)
  fileSize     Int?          // In bytes, for file uploads
  publishAt    DateTime?     // Scheduled publish date/time (stored as UTC)
  status       PublishStatus @default(DRAFT) // DRAFT, SCHEDULED, PUBLISHED
  isVisible    Boolean       @default(true) // Manual visibility toggle
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("answers")
}

enum AnswerType {
  PDF
  IMAGE
  YOUTUBE
  DRIVE           // Legacy - kept for database compatibility (cannot be removed from PostgreSQL enum)
  EXTERNAL_LINK   // Current - use this for new external link answers
}

enum CategoryType {
  LESSON
  UNIT_EXERCISE
  EXAM
  OTHER
}

enum PublishStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
}

// Quiz model for storing quizzes (Google Forms embeds)
model Quiz {
  id              String        @id @default(cuid())
  title           String        // "اختبار الدرس الأول" or "اختبار على الوحدة 1"
  description     String?       @db.Text
  googleFormUrl   String        // Google Forms embed URL
  lessonId        String?
  lesson          Lesson?       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  unitId          String?       // Direct unit reference for unit-level quizzes
  unit            Unit?         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  gradeId         String?       // Direct grade reference for grade-level quizzes
  grade           Grade?        @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  categoryType    CategoryType  // LESSON, UNIT_EXERCISE, EXAM, OTHER
  customTitle     String?       // For OTHER category type
  order           Int           @default(0)
  duration        Int?          // Estimated duration in minutes (for display)
  publishAt       DateTime?     // Scheduled publish date/time (stored as UTC)
  status          PublishStatus @default(DRAFT) // DRAFT, SCHEDULED, PUBLISHED
  isVisible       Boolean       @default(true) // Manual visibility toggle
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@map("quizzes")
}

// Activity tracking for dashboard
model Activity {
  id          String       @id @default(cuid())
  action      ActivityType // CREATE, UPDATE, DELETE
  entityType  String       // "grade", "unit", "lesson", "answer"
  entityId    String?      // ID of the affected entity
  entityName  String       // Name/title for display
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now())

  @@map("activities")
  @@index([createdAt(sort: Desc)])
}

enum ActivityType {
  CREATE
  UPDATE
  DELETE
  SCHEDULE
  PUBLISH
  RESCHEDULE
}

// Student model for "لوحة الشرف" (Best Students)
model Student {
  id           String          @id @default(cuid())
  name         String          // Student's full name in Arabic
  gradeId      String
  grade        Grade           @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  studentGrade Int             // Student's grade (e.g., 29)
  testGrade    Int             // Test total grade (e.g., 30)
  position     StudentPosition @default(NONE) // FIRST, SECOND, THIRD, NONE
  image        String?         // Path to student's image (optional - will show avatar placeholder if null)
  isVisible    Boolean         @default(true)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@map("students")
  @@index([gradeId])
  @@index([position])
}

// Live sessions for online English lessons and revisions
model LiveSession {
  id              String              @id @default(cuid())
  title           String
  description     String?             @db.Text
  sessionLink     String
  sessionDateTime DateTime
  durationMinutes Int                 @default(120)
  gradeId         String
  grade           Grade               @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  codes           SessionCode[]
  attendance      SessionAttendance[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@map("live_sessions")
  @@index([gradeId])
  @@index([sessionDateTime])
}

model SessionCode {
  id           String              @id @default(cuid())
  sessionId    String
  session      LiveSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  gradeId      String
  grade        Grade               @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  code         String              @unique
  isRedeemed   Boolean             @default(false)
  redeemedAt   DateTime?
  attendance   SessionAttendance?
  createdAt    DateTime            @default(now())

  @@map("session_codes")
  @@index([sessionId])
  @@index([gradeId])
  @@index([isRedeemed])
  @@index([redeemedAt])
}

model SessionAttendance {
  id        String      @id @default(cuid())
  sessionId String
  session   LiveSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  codeId    String      @unique
  code      SessionCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  enteredAt DateTime    @default(now())

  @@map("session_attendance")
  @@index([sessionId])
  @@index([enteredAt])
}

enum StudentPosition {
  FIRST
  SECOND
  THIRD
  NONE
}

// File model for tracking all uploaded files with metadata
model File {
  id             String       @id @default(cuid())
  path           String       @unique // Web-accessible path (e.g., "/answers/prep-1/unit-id/file.pdf")
  type           FileType     // PDF, IMAGE, THUMBNAIL
  size           Int          // File size in bytes
  originalName   String       // Original filename when uploaded
  mimeType       String?      // MIME type (e.g., "application/pdf", "image/webp")
  usedIn         FileUsage    // ANSWER, STUDENT, OTHER
  linkedRecordId String?      // ID of the related Answer/Student record
  uploadedBy     String?      // User ID who uploaded the file
  uploader       User?        @relation("UploadedFiles", fields: [uploadedBy], references: [id], onDelete: SetNull)
  isOrphaned     Boolean      @default(false) // Flagged when no longer referenced
  isActive       Boolean      @default(true) // False when versioned/archived
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  
  versions       FileVersion[]

  @@map("files")
  @@index([usedIn])
  @@index([linkedRecordId])
  @@index([isOrphaned])
  @@index([isActive])
  @@index([createdAt(sort: Desc)])
}

enum FileType {
  PDF
  IMAGE
  THUMBNAIL
}

enum FileUsage {
  ANSWER
  STUDENT
  OTHER
}

// FileVersion model for tracking file version history (for rollback)
model FileVersion {
  id            String   @id @default(cuid())
  fileId        String
  file          File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
  path          String   // Path to the versioned file in .versions/ directory
  versionNumber Int      // Sequential version number (1, 2, 3...)
  size          Int      // File size in bytes
  createdBy     String?  // User ID who created this version
  creator       User?    @relation("CreatedVersions", fields: [createdBy], references: [id], onDelete: SetNull)
  changeReason  String?  // Why the version was created (e.g., "Replaced with new file", "Deleted")
  createdAt     DateTime @default(now())

  @@map("file_versions")
  @@unique([fileId, versionNumber])
  @@index([fileId])
  @@index([createdAt(sort: Desc)])
}
